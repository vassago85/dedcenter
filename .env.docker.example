# Copy to ".env" in this folder for Docker Desktop local stack:
#   copy .env.docker.example .env   (Windows PowerShell: Copy-Item)
# Then set APP_KEY (see DOCKER_DESKTOP.md) and optionally change passwords.
#
# Run: docker compose -f docker-compose.local.yml up --build -d
# App: http://localhost:8091
# MySQL on host: localhost:3307 (user/password below)

APP_NAME=DeadCenter
APP_ENV=local
# Pre-generated for local Docker only — run `php artisan key:generate` if you prefer a fresh key
APP_KEY="base64:S/dX9z/blDSMNeifE1y79HFitPCVyhFR50E4O/e8SPM="
APP_DEBUG=true
APP_URL=http://localhost:8091
APP_TIMEZONE=Africa/Johannesburg

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Published HTTP port (host) — must match APP_URL port
APP_PORT=8091

# MySQL exposed on host for GUI tools (DBeaver, etc.)
DB_HOST_PORT=3307

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=deadcenter
DB_USERNAME=deadcenter
DB_PASSWORD=deadcenter_local_secret
DB_ROOT_PASSWORD=deadcenter_root_secret

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave unset for localhost cookies, or set empty in .env
# SESSION_DOMAIN=

QUEUE_CONNECTION=redis

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8091,127.0.0.1,127.0.0.1:8091

# Single-host local dev (optional: add 127.0.0.1 md.localhost to hosts for MD UI)
DOMAIN_SHOOTER=localhost
DOMAIN_MD=localhost
DOMAIN_APP=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="dev@deadcenter.test"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
